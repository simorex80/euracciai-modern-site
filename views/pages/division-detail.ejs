<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow"><%= t.pages.divisionEyebrow %></span>
    <h1 class="accent-<%= division.color %>"><%= division.title %></h1>
    <p><%= division.subtitle %></p>
  </section>
  <section class="section split">
    <img class="detail-img" src="<%= asset(division.image) %>" alt="<%= division.title %>">
    <div>
      <h2><%= division.description %></h2>
      <% division.paragraphs.forEach((paragraph) => { %>
        <p><%= paragraph %></p>
      <% }) %>
      <a class="btn btn-primary" href="<%= url(pathFor('contatti')) %>"><%= t.common.contacts %></a>
    </div>
  </section>
  <section class="section value-section">
    <span class="eyebrow"><%= t.pages.contentEyebrow %></span>
    <h2><%= t.pages.contentTitle %></h2>
    <div class="value-grid compact-list">
      <% division.products.forEach((item) => { %>
        <div>
          <h3><%= typeof item === 'string' ? item : item.title %></h3>
          <% if (typeof item !== 'string' && item.description) { %>
            <p><%= item.description %></p>
          <% } %>
          <% if (typeof item !== 'string' && item.url) { %>
            <p><a href="<%= item.url %>" target="_blank" rel="noopener noreferrer"><%= item.url %></a></p>
          <% } %>
        </div>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
