<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow"><%= t.pages.productsEyebrow %></span>
    <h1><%= t.pages.productsTitle %></h1>
    <p><%= t.pages.productsSubtitle %></p>
  </section>
  <section class="cards-grid section">
    <% divisions.forEach((division) => { %>
      <article class="division-card">
        <img src="<%= asset(division.image) %>" alt="<%= division.title %>">
        <div class="card-body">
          <h3 class="accent-<%= division.color %>"><%= division.name %></h3>
          <strong><%= division.subtitle %></strong>
          <p><%= division.description %></p>
          <a href="<%= url(pathFor('divisioni', { id: division.id })) %>"><%= t.common.detail %></a>
        </div>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/footer') %>
