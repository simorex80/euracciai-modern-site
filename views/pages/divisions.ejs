<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow">Prodotti</span>
    <h1>Divisioni</h1>
    <p>MDU, MACSI e DIVMAC.</p>
  </section>
  <section class="cards-grid section">
    <% divisions.forEach((division) => { %>
      <article class="division-card">
        <img src="<%= division.image %>" alt="<%= division.title %>">
        <div class="card-body">
          <h3 class="accent-<%= division.color %>"><%= division.name %></h3>
          <strong><%= division.subtitle %></strong>
          <p><%= division.description %></p>
          <a href="/divisioni/<%= division.id %>">Approfondisci →</a>
        </div>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/footer') %>
