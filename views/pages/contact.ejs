<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow"><%= t.common.contacts %></span>
    <h1><%= t.common.contacts %></h1>
  </section>
  <section class="section contact-layout">
    <div class="contact-card">
      <h2><%= t.common.contacts %></h2>
      <p><strong><%= t.common.phone %></strong><br><%= site.phoneExtended %></p>
      <p><strong><%= t.common.fax %></strong><br><%= site.fax %></p>
      <p><strong><%= t.common.email %></strong><br><a href="mailto:<%= site.email %>"><%= site.email %></a></p>
      <p><strong><%= t.common.office %></strong><br><%= site.address %></p>
      <hr>
      <% divisions.forEach((division) => { %>
        <p><strong><%= t.common.division.toUpperCase() %> <%= division.name === 'DIVMAC' ? 'DIVMAC' : division.name %></strong><br><%= division.subtitle %><br><a href="mailto:<%= division.email %>"><%= division.email %></a></p>
      <% }) %>
    </div>
    <div class="contact-card">
      <h2><%= t.common.directions %></h2>
      <p><strong><%= site.directions.metroTitle %></strong><br><%= site.directions.metroText %></p>
      <p><strong><%= site.directions.carTitle %></strong><br><%= site.directions.carText %></p>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
