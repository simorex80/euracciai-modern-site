<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow">Contatti</span>
    <h1>Contatti</h1>
  </section>
  <section class="section contact-layout">
    <div class="contact-card">
      <h2>Contatti</h2>
      <p><strong>Telefono</strong><br><%= site.phoneExtended %></p>
      <p><strong>Fax</strong><br><%= site.fax %></p>
      <p><strong>Email</strong><br><%= site.email %></p>
      <p><strong>Sede</strong><br><%= site.address %></p>
      <hr>
      <% divisions.forEach((division) => { %>
        <p><strong>DIVISIONE <%= division.name === 'DIVMAC' ? 'DIVMAC' : division.name %></strong><br><%= division.subtitle %><br><%= division.email %></p>
      <% }) %>
    </div>
    <div class="contact-card">
      <h2>Come raggiungerci</h2>
      <p><%= site.directions %></p>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
