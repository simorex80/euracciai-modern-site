<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content reveal visible">
      <span class="eyebrow">Euracciai</span>
      <h1><span>Since 1958</span></h1>
      <p><%= t.home.intro %></p>
      <div class="actions">
        <a class="btn btn-primary" href="<%= pathFor('divisioni') %>"><%= t.home.ctaProducts %></a>
        <a class="btn btn-ghost" href="<%= pathFor('azienda') %>"><%= t.home.ctaCompany %></a>
      </div>
      <div class="hero-badges">
        <div><strong>1958</strong><small><%= t.home.startActivity %></small></div>
        <div><strong>3</strong><small><%= t.home.divisionsCount %></small></div>
      </div>
    </div>
  </section>

  <section class="section split reveal">
    <div>
      <span class="eyebrow"><%= t.home.divisionsTitle %></span>
      <h2><%= t.home.divisionsHeadline %></h2>
    </div>
    <p><%= t.home.divisionsLead %></p>
  </section>

  <section class="cards-grid section-tight">
    <% divisions.forEach((division) => { %>
      <article class="division-card reveal">
        <img src="<%= division.image %>" alt="<%= division.title %>">
        <div class="card-body">
          <h3 class="accent-<%= division.color %>"><%= division.name %></h3>
          <strong><%= division.subtitle %></strong>
          <p><%= division.description %></p>
          <a href="<%= pathFor('divisioni', { id: division.id }) %>"><%= t.home.cardOpen %> <%= division.name %> →</a>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="section reveal" id="azienda">
    <span class="eyebrow"><%= t.home.aboutTitle %></span>
    <h2><%= t.home.aboutHeadline %></h2>
    <% company.paragraphs.forEach((paragraph) => { %>
      <p class="section-lead"><%= paragraph %></p>
    <% }) %>
  </section>
</main>

<%- include('../partials/footer') %>
