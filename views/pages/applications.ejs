<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow"><%= t.pages.applicationsEyebrow %></span>
    <h1><%= t.pages.applicationsTitle %></h1>
    <p><%= t.pages.applicationsSubtitle %></p>
  </section>
  <section class="section">
    <div class="sector-grid large">
      <% applications.forEach((item) => { %>
        <div class="sector-card"><span><%= item %></span></div>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
