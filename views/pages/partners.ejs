<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="page">
  <section class="page-hero">
    <span class="eyebrow"><%= t.pages.partnersEyebrow %></span>
    <h1><%= t.pages.partnersTitle %></h1>
    <p><%= t.pages.partnersSubtitle %></p>
  </section>
  <section class="section">
    <div class="value-grid compact-list partners-grid">
      <% partners.forEach((partner) => { %>
        <article class="partner-card">
          <h3><%= partner.name %> - <%= partner.country %></h3>
          <p><strong><%= t.common.division %>:</strong> <%= partner.division %></p>
          <p><%= partner.description %></p>
          <% if (partner.url) { %>
            <p><a href="<%= partner.url %>" target="_blank" rel="noopener noreferrer"><%= partner.url %></a></p>
          <% } %>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
