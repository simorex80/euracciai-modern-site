<header class="site-header">
  <a class="brand" href="<%= pathFor('home') %>" aria-label="Home">
    <span class="brand-mark">E</span>
    <span>
      <strong><%= site.company %></strong>
      <small><%= site.payoff %></small>
    </span>
  </a>
  <nav class="main-nav" aria-label="Navigazione principale">
    <a class="<%= page === 'azienda' ? 'active' : '' %>" href="<%= pathFor('azienda') %>"><%= t.nav.azienda %></a>
    <a class="<%= page === 'divisioni' ? 'active' : '' %>" href="<%= pathFor('divisioni') %>"><%= t.nav.divisioni %></a>
    <a class="<%= page === 'applicazioni' ? 'active' : '' %>" href="<%= pathFor('applicazioni') %>"><%= t.nav.applicazioni %></a>
    <a class="<%= page === 'partners' ? 'active' : '' %>" href="<%= pathFor('partners') %>"><%= t.nav.partners %></a>
    <a class="<%= page === 'contatti' ? 'active' : '' %>" href="<%= pathFor('contatti') %>"><%= t.nav.contatti %></a>
  </nav>
  <a class="btn btn-ghost header-cta" href="<%= switchPath %>"><%= t.switchLabel %></a>
</header>
