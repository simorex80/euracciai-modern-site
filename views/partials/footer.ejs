<footer class="site-footer">
  <div class="footer-cta">
    <div>
      <span class="eyebrow">Contatti</span>
      <h2><%= site.company %></h2>
    </div>
    <p><%= site.address %><br>Tel <%= site.phone %> - Fax <%= site.fax %><br><%= site.email %></p>
    <a class="btn btn-primary" href="/contatti">Contatti</a>
  </div>

  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href="/">
        <span class="brand-mark">E</span>
        <span><strong><%= site.company %></strong><small><%= site.payoff %></small></span>
      </a>
    </div>
    <div>
      <h3>Menu</h3>
      <a href="/azienda">Chi siamo</a>
      <a href="/divisioni">Prodotti</a>
      <a href="/partners">Partners</a>
      <a href="/contatti">Contatti</a>
    </div>
    <div>
      <h3>Divisioni</h3>
      <% divisions.forEach((division) => { %>
        <a href="/divisioni/<%= division.id %>"><%= division.name %> — <%= division.subtitle %></a>
      <% }) %>
    </div>
    <div>
      <h3>Dati societari</h3>
      <p><%= site.chamber %></p>
      <p><%= site.capital %></p>
      <p><%= site.registry %></p>
      <p><%= site.vat %></p>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© <%= new Date().getFullYear() %> <%= site.company %></span>
  </div>
</footer>
<script src="/js/main.js"></script>
</body>
</html>
