<footer class="site-footer">
  <div class="footer-cta">
    <div>
      <span class="eyebrow"><%= t.common.contacts %></span>
      <h2><%= site.company %></h2>
    </div>
    <p><%= site.address %><br><%= t.common.phone %> <%= site.phone %> - <%= t.common.fax %> <%= site.fax %><br><%= site.email %></p>
    <a class="btn btn-primary" href="<%= url(pathFor('contatti')) %>"><%= t.common.contacts %></a>
  </div>

  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href="<%= url(pathFor('home')) %>">
        <span class="brand-mark">E</span>
        <span><strong><%= site.company %></strong><small><%= site.payoff %></small></span>
      </a>
    </div>
    <div>
      <h3><%= t.common.menu %></h3>
      <a href="<%= url(pathFor('azienda')) %>"><%= t.nav.azienda %></a>
      <a href="<%= url(pathFor('divisioni')) %>"><%= t.nav.divisioni %></a>
      <a href="<%= url(pathFor('partners')) %>"><%= t.nav.partners %></a>
      <a href="<%= url(pathFor('contatti')) %>"><%= t.nav.contatti %></a>
    </div>
    <div>
      <h3><%= t.home.divisionsTitle %></h3>
      <% divisions.forEach((division) => { %>
        <a href="<%= url(pathFor('divisioni', { id: division.id })) %>"><%= division.name %> — <%= division.subtitle %></a>
      <% }) %>
    </div>
    <div>
      <h3><%= t.common.companyData %></h3>
      <p><%= site.chamber %></p>
      <p><%= site.capital %></p>
      <p><%= site.registry %></p>
      <p><%= site.vat %></p>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© <%= new Date().getFullYear() %> <%= site.company %></span>
    <div class="lang-switch footer-lang" aria-label="Language selector">
      <a class="lang-link <%= locale === 'it' ? 'active' : '' %>" href="<%= url(localePaths.it) %>">IT</a>
      <span>/</span>
      <a class="lang-link <%= locale === 'en' ? 'active' : '' %>" href="<%= url(localePaths.en) %>">EN</a>
    </div>
  </div>
</footer>
<script src="<%= asset('/js/main.js') %>"></script>
</body>
</html>
